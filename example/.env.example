# Bootpay 환경 설정 (예시)
#
# 사용법:
#   1. 이 파일을 `.env`로 복사
#   2. 필요한 키만 주석 해제 + 값 채우기
#   3. 미설정 키는 production 기본값(BootpayEnvConfig)으로 자동 fallback
#
# 배포 기본값은 항상 production. `.env`는 .gitignore 처리됨.

# 환경 스위치 (development | production)
# BOOTPAY_ENV=development

# PG API - Application ID (플랫폼별)
# BOOTPAY_WEB_APPLICATION_ID_DEV=5b9f51264457636ab9a07cdb
# BOOTPAY_WEB_APPLICATION_ID_PROD=5b8f6a4d396fa665fdc2b5e7
# BOOTPAY_ANDROID_APPLICATION_ID_DEV=5b9f51264457636ab9a07cdc
# BOOTPAY_ANDROID_APPLICATION_ID_PROD=5b8f6a4d396fa665fdc2b5e8
# BOOTPAY_IOS_APPLICATION_ID_DEV=5b9f51264457636ab9a07cdd
# BOOTPAY_IOS_APPLICATION_ID_PROD=5b8f6a4d396fa665fdc2b5e9

# PG API - REST Application ID (EasyPay/REST 전용)
# BOOTPAY_REST_APPLICATION_ID_DEV=59b731f084382614ebf72215
# BOOTPAY_REST_APPLICATION_ID_PROD=5b8f6a4d396fa665fdc2b5ea

# Commerce API - Client Key
# BOOTPAY_CLIENT_KEY_DEV=hxS-Up--5RvT6oU6QJE0JA
# BOOTPAY_CLIENT_KEY_PROD=sEN72kYZBiyMNytA8nUGxQ
